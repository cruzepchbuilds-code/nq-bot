# ── Discord ──────────────────────────────────────────────────────────────
# Discord Developer Portal -> Applications -> your app -> Bot -> Token
DISCORD_BOT_TOKEN=

# Server (guild) to operate in. Right-click the server icon -> Copy Server ID
# (enable Developer Mode in Discord: Settings -> Advanced -> Developer Mode)
DISCORD_GUILD_ID=

# ── Per-agent bot tokens (5 separate Discord Applications) ─────────────────
# Create 5 applications in the Discord Developer Portal (one per agent),
# paste each bot token here. "ops" can reuse DISCORD_BOT_TOKEN above.
# Then run: set_identity.py <agent>, invite_link.py <agent>, assign_role.py <agent>
DISCORD_BOT_TOKEN_OPS=
DISCORD_BOT_TOKEN_CI=
DISCORD_BOT_TOKEN_REVIEW=
DISCORD_BOT_TOKEN_DEPLOY=
DISCORD_BOT_TOKEN_RESEARCH=

# ── Filled in automatically by setup_server.py ──────────────────────────────
# Channel IDs (used by bot.py cogs for slash commands / scheduled posts)
CHANNEL_CI_CD=
CHANNEL_CODE_REVIEW=
CHANNEL_DEPLOYMENTS=
CHANNEL_RESEARCH_ALERTS=
CHANNEL_BOT_STATUS=
CHANNEL_OPS_LOG=
CHANNEL_GENERAL=
CHANNEL_ANNOUNCEMENTS=
CHANNEL_AGENT_GENERAL=

# Quant trading desk (setup_quant_desk.py)
CHANNEL_PRE_MARKET=
CHANNEL_SIGNALS=
CHANNEL_TRADE_LOG=
CHANNEL_DAILY_PNL=
CHANNEL_RISK_ALERTS=
CHANNEL_ACCOUNT_STATUS=
CHANNEL_NQ_STRATEGY=
CHANNEL_ES_STRATEGY=
CHANNEL_WALK_FORWARD=
CHANNEL_BRAIN_INSIGHTS=

# Incoming webhook URLs (used by webhook_server.py to post without the bot
# needing to be online) — created automatically by setup_server.py
WEBHOOK_CI_CD=
WEBHOOK_CODE_REVIEW=
WEBHOOK_DEPLOYMENTS=
WEBHOOK_RESEARCH_ALERTS=

# ── GitHub integration (optional) ───────────────────────────────────────────
# Personal access token with repo:read scope (for /ci and /review commands)
GITHUB_TOKEN=
GITHUB_REPO=cruzepchbuilds-code/nq_bot_final

# Shared secret configured in GitHub repo -> Settings -> Webhooks
# Used by webhook_server.py to verify incoming payloads
GITHUB_WEBHOOK_SECRET=

# ── webhook_server.py ────────────────────────────────────────────────────────
WEBHOOK_SERVER_PORT=8787

# ── Project paths (for the Research agent) ──────────────────────────────────
NQ_BOT_PROJECT_DIR=/Users/Cruz/Desktop/nq_bot_final
