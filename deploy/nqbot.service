[Unit]
Description=CruzCapital NQ Trading Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=nqbot
WorkingDirectory=/home/nqbot/nq_bot
EnvironmentFile=/home/nqbot/nq_bot/.env
ExecStart=/home/nqbot/nq_bot/venv/bin/python live/paper_trading.py
Restart=always
RestartSec=30
StandardOutput=append:/home/nqbot/logs/trading.log
StandardError=append:/home/nqbot/logs/trading.log

[Install]
WantedBy=multi-user.target
